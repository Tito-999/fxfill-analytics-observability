# FxFill Analytics — Environment Configuration
# Copy this file to .env and adjust values for your environment.
# WARNING: Never commit .env to version control.

# ── General ──
PROJECT_NAME=FxFill Analytics
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Paths ──
DATA_DIR=./data
WAREHOUSE_PATH=./warehouse/fxfill.duckdb
CONFIG_DIR=./config

# ── Data Generation ──
# Options: tiny | small | medium | large
DATA_SIZE=medium
DATA_SEED=20260616

# ── Database ──
DUCKDB_PATH=./warehouse/fxfill.duckdb
DUCKDB_READ_ONLY=false

# ── dbt ──
DBT_PROJECT_DIR=./dbt_fxfill
DBT_PROFILES_DIR=./dbt_fxfill

# ── API ──
API_HOST=127.0.0.1
API_PORT=8000
API_KEY=dev-key-change-in-production

# ── Dashboard ──
STREAMLIT_PORT=8501

# ── Optional: LLM / Analytics Copilot ──
# Options: mock | openai | ollama
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_API_BASE=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Optional: External Observability ──
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

POSTHOG_ENABLED=false
POSTHOG_API_KEY=
POSTHOG_HOST=

# ── Optional: Experiment Tracking ──
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=
